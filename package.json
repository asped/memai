{
  "name": "memai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "API-first funny image generator with web, Slack, and MCP integrations",
  "scripts": {
    "dev": "NODE_USE_SYSTEM_CA=1 tsx watch src/index.ts",
    "dev:mcp": "NODE_USE_SYSTEM_CA=1 tsx src/mcp.ts",
    "build": "tsc -p tsconfig.json",
    "start": "NODE_USE_SYSTEM_CA=1 node dist/src/index.js",
    "start:mcp": "NODE_USE_SYSTEM_CA=1 node dist/src/mcp.js",
    "test": "node --import tsx --test 'test/**/*.test.ts'",
    "check": "npm run build && npm test"
  },
  "engines": {
    "node": ">=22.19"
  },
  "dependencies": {
    "@img/sharp-wasm32": "^0.35.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@netlify/blobs": "^10.7.9",
    "@netlify/functions": "^5.3.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "openai": "^6.46.0",
    "sharp": "^0.35.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  }
}
