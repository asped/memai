# Required for real image generation
OPENAI_API_KEY=

# Image generation defaults
OPENAI_IMAGE_MODEL=gpt-image-2
IMAGE_QUALITY=low
IMAGE_SIZE=640x640

# Public address where generated images are reachable.
# Netlify automatically falls back to its built-in URL when this is empty.
PUBLIC_BASE_URL=http://localhost:4317
PORT=4317

# Required bearer token for POST /v1/images and MCP clients
API_TOKEN=

# Browser login. Use a long random password and session secret in production.
BROWSER_USERNAME=admin
BROWSER_PASSWORD=
SESSION_SECRET=

# Required only for the Slack slash command
SLACK_SIGNING_SECRET=
# Optional: lock Slack generation to one workspace ID (for example T01234567)
SLACK_TEAM_ID=

# Used by the standalone MCP process
MEMAI_API_URL=http://localhost:4317
MEMAI_API_TOKEN=
